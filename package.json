{
  "name": "unitium",
  "version": "0.6.0",
  "description": "Class based unit testing for node & the browser",
  "keywords": [
    "test-runner",
    "unit-testing",
    "class-based",
    "typescript"
  ],
  "type": "module",
  "types": "./distribution/suite-api.d.ts",
  "module": "./distribution/suite-api.js",
  "main": "./distribution/suite-api.js",
  "exports": {
    ".": {
      "types": "./distribution/suite-api.d.ts",
      "bun": "./distribution/suite-api.js",
      "deno": "./distribution/suite-api.js",
      "import": "./distribution/suite-api.js"
    },
    "./browser/*": "./distribution/environments/browser/*",
    "./bun": {
      "types": "./distribution/environments/cli/bun/api.d.ts",
      "bun": "./distribution/environments/cli/bun/api.js",
      "import": "./distribution/environments/cli/bun/api.js"
    },
    "./deno": {
      "types": "./distribution/environments/cli/deno/api.d.ts",
      "deno": "./distribution/environments/cli/deno/api.js",
      "import": "./distribution/environments/cli/deno/api.js"
    },
    "./node-api": "./distribution/environments/cli/node/api.js",
    "./browser-api": "./distribution/environments/browser/api.js"
  },
  "imports": {
    "#unitium/assert": {
      "deno": "./tests/adaptors/assert.deno.ts",
      "bun": "./tests/adaptors/assert.node.ts",
      "node": "./tests/adaptors/assert.node.ts",
      "default": "./tests/adaptors/assert.node.ts"
    },
    "#unitium/test-runtime": {
      "deno": "./tests/adaptors/runtime.deno.ts",
      "bun": "./tests/adaptors/runtime.node.ts",
      "node": "./tests/adaptors/runtime.node.ts",
      "default": "./tests/adaptors/runtime.node.ts"
    }
  },
  "author": "Magnus Meseck",
  "license": "MIT",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "unitium": "/distribution/cli.js",
    "unitium-tsx": "/distribution/environments/cli/node/exec-tsx.js",
    "unitium-ts-node": "/distribution/environments/cli/node/exec-ts-node.js"
  },
  "scripts": {
    "dry-update": "node npm-release.ts",
    "patch": "node npm-release.ts && npm version patch && git push && npm publish",
    "release": "node npm-release.ts && npm version minor && git push && npm publish",
    "test": "npm run test:node",
    "test:node": "node ./source/cli.ts ./source",
    "test:bun": "bun ./source/cli.ts ./source",
    "test:deno": "deno run --allow-read ./source/cli.ts ./source",
    "serve": "vite"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "typescript": "^5.8.0",
    "uvu": "^0.5.6"
  },
  "dependencies": {
    "deferium": "^0.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elemental-mind/unitium.git"
  },
  "homepage": "https://github.com/elemental-mind/unitium#readme"
}
