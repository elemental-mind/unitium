{
  "name": "unitium",
  "version": "0.7.0",
  "description": "Class based unit testing for Node, Bun, Deno & the browser",
  "keywords": [
    "test-runner",
    "unit-testing",
    "class-based",
    "typescript"
  ],
  "type": "module",
  "types": "./test-suite-api.d.ts",
  "module": "./test-suite-api.js",
  "main": "./test-suite-api.js",
  "exports": {
    ".": {
      "types": "./test-suite-api.d.ts",
      "import": "./test-suite-api.js"
    },
    "./runner-api": {
      "types": "./runner-api.d.ts",
      "import": "./runner-api.js"
    },
    "./browser/*": "./environments/browser/*",
    "./browser-api": "./environments/browser/api.js"
  },
  "author": "Magnus Meseck",
  "license": "MIT",
  "engines": {
    "node": ">=22.18"
  },
  "bin": {
    "unitium": "./cli.js",
    "unitium-tsx": "./environments/cli/node/exec-tsx.js",
    "unitium-ts-node": "./environments/cli/node/exec-ts-node.js"
  },
  "dependencies": {
    "deferium": "^0.1.1",
    "ignore": "^7.0.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elemental-mind/unitium.git"
  },
  "homepage": "https://github.com/elemental-mind/unitium#readme"
}
